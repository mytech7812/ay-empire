{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/admin",
      "destination": "/admin/login",
      "permanent": false
    },
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/admin/login",
      "destination": "/admin/login.html"
    },
    {
      "source": "/admin/dashboard",
      "destination": "/admin/dashboard.html"
    },
    {
      "source": "/admin/orders",
      "destination": "/admin/orders.html"
    },
    {
      "source": "/admin/products",
      "destination": "/admin/products.html"
    },
    {
      "source": "/admin/sales",
      "destination": "/admin/sales.html"
    }
  ]
}
